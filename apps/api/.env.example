APP_ENV=local
LOG_LEVEL=INFO

# App connection — uses the NOSUPERUSER NOBYPASSRLS role so RLS enforces.
DATABASE_URL=postgresql+asyncpg://strata_app:strata_app@postgres:5432/strata
# Migrations need ownership + extension privileges; alembic uses this URL,
# the rest of the app uses DATABASE_URL. Falls back to DATABASE_URL if unset.
MIGRATION_DATABASE_URL=postgresql+asyncpg://strata:strata@postgres:5432/strata
REDIS_URL=redis://redis:6379/0

# Internal endpoint used by the API + worker for server-side calls.
MINIO_ENDPOINT=minio:9000
# Browser-reachable endpoint used only when minting presigned upload URLs.
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=strata
MINIO_SECRET_KEY=strata-secret
MINIO_BUCKET=strata
MINIO_SECURE=false
MINIO_PUBLIC_SECURE=false

PARQUET_ROOT=/data/parquet

BACKEND_JWT_SECRET=dev-insecure-change-me
ANTHROPIC_API_KEY=

# Stripe — leave blank to disable billing (org defaults to Free, checkout 503s).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_TEAM_PRICE_ID=
STRIPE_SUCCESS_URL=https://app.localhost/settings/billing?status=success
STRIPE_CANCEL_URL=https://app.localhost/settings/billing?status=cancelled
STRIPE_PORTAL_RETURN_URL=https://app.localhost/settings/billing

# Google OAuth (sheets sync) — also used for Google sign-in.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Share links — falls back to BACKEND_JWT_SECRET if blank.
# Rotate this to invalidate every outstanding share link in one shot.
SHARE_LINK_SECRET=

# Observability
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0
LOG_FORMAT=json

# Super-admin portal — comma-separated email allowlist. Server-only.
# Anyone whose user.email matches (case-insensitive) can call /api/admin/*.
# Leave blank to lock the portal entirely (all requests return 404).
SUPERADMIN_EMAILS=

# OAuth token encryption — AES-256-GCM key for access/refresh tokens at rest.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# Must match the OAUTH_TOKEN_ENCRYPTION_KEY in apps/web/.env.
# Leave blank to disable encryption (tokens stored plaintext).
OAUTH_TOKEN_ENCRYPTION_KEY=
