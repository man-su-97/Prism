# Backend
API_BASE_URL=http://api:8000
BACKEND_JWT_SECRET=dev-insecure-change-me

# Better Auth
BETTER_AUTH_SECRET=dev-insecure-change-me
BETTER_AUTH_URL=https://app.localhost
NEXT_PUBLIC_APP_URL=https://app.localhost
# Comma-separated extra Origin header values that the auth endpoints accept.
# http://localhost:3000 and https://app.localhost are always included.
BETTER_AUTH_TRUSTED_ORIGINS=

# Auth DB connection (sync driver for Better Auth's pg adapter). Uses the
# NOSUPERUSER NOBYPASSRLS role so future RLS tables are not silently read
# across tenants via the auth path.
AUTH_DATABASE_URL=postgresql://strata_app:strata_app@postgres:5432/strata

# Optional Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SMTP — used for workspace invitation emails and password-reset links.
# Leave SMTP_HOST blank to disable outbound mail; the mailer will log the
# email payload (including the invite/reset URL) to stdout so local dev
# still works without a mailbox.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="InsightBoard <noreply@example.com>"

# Super-admin portal — comma-separated email allowlist. Server-only,
# never exposed to the browser. Anyone whose Better Auth user.email
# matches (case-insensitive) can reach /admin/*. Leave blank to lock
# the portal entirely (/admin returns 404).
SUPERADMIN_EMAILS=

# OAuth token encryption — AES-256-GCM key for access/refresh tokens at rest.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must match the OAUTH_TOKEN_ENCRYPTION_KEY in apps/api/.env.
# Leave blank to disable encryption (tokens stored plaintext).
OAUTH_TOKEN_ENCRYPTION_KEY=
